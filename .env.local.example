# ─── Strapi CMS ──────────────────────────────────────────────────────
# Base URL of your Strapi instance (no trailing slash)
NEXT_PUBLIC_STRAPI_URL=http://localhost:1337

# Optional: Strapi API Token for authenticated requests
# Generate at: Strapi Admin → Settings → API Tokens
STRAPI_API_TOKEN=

# Optional: Hostname for Strapi media (for next.config.js image optimization)
STRAPI_MEDIA_HOST=localhost

# ─── Site Config ─────────────────────────────────────────────────────
# Your frontend production URL (used for sitemap, OG tags, canonical URLs)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Site name shown in metadata and structured data
NEXT_PUBLIC_SITE_NAME=MySite
